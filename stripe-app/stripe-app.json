{
  "$schema": "https://stripe.com/stripe-app.schema.json",
  "id": "com.example.invoicetemplate",
  "name": "Zendesk Connector",
  "version": "0.0.197",
  "icon": "./icon.png",
  "ui_extension": {
    "views": [
      {
        "viewport": "stripe.dashboard.drawer.default",
        "component": "App"
      },
      {
        "viewport": "stripe.dashboard.customer.detail",
        "component": "CustomerDetailApp"
      }
    ],
    "content_security_policy": {
      "connect-src": [
        "https://gbtzgszldsarfwzcqoiz.supabase.co/functions/v1/",
        "https://gbtzgszldsarfwzcqoiz.supabase.co/storage/v1/"
      ],
      "image-src": [
        "https://gbtzgszldsarfwzcqoiz.supabase.co/storage/v1/object/public/assets/"
      ],
      "purpose": "All Zendesk API calls and OAuth flows are proxied through Supabase edge functions to avoid CORS restrictions in the Stripe Apps sandbox"
    }
  },
  "extensions": null,
  "permissions": [
    {
      "permission": "customer_read",
      "purpose": "Read Stripe customer email to look up matching Zendesk tickets"
    },
    {
      "permission": "secret_write",
      "purpose": "Store and refresh Zendesk OAuth tokens securely in Stripe Secret Store"
    }
  ],
  "distribution_type": "public"
}